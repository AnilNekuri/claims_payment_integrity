# Copy to .env for local-only testing. Do not commit .env.

AWS_REGION=us-east-1
AWS_PROFILE=your-aws-profile

EKS_CLUSTER_NAME=claims-integrity-dev
K8S_NAMESPACE=claims-integrity

MSK_BOOTSTRAP_SERVERS=b-1.example.kafka.us-east-1.amazonaws.com:9092,b-2.example.kafka.us-east-1.amazonaws.com:9092
KAFKA_TOPIC=claim-events
KAFKA_CONSUMER_GROUP=claims-rules-engine

RDS_HOST=claims-integrity-dev.example.us-east-1.rds.amazonaws.com
RDS_PORT=5432
RDS_DB_NAME=claims_integrity
RDS_USER=claims_app
RDS_PASSWORD=replace-with-local-only-password

SPLUNK_HEC_URL=https://splunk.example.com:8088/services/collector
SPLUNK_HEC_TOKEN=replace-with-local-only-token
